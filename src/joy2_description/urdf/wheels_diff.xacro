<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="joy2_diff_wheels">
  <xacro:property name="DIFF_WHEEL_RADIUS" value="0.06"/>
  <xacro:property name="DIFF_WHEEL_WIDTH" value="0.03"/>
  <xacro:property name="DIFF_WHEEL_MASS" value="0.08"/>

  <xacro:property name="DIFF_WHEEL_X_OFFSET" value="0.14"/>
  <xacro:property name="DIFF_WHEEL_Y_OFFSET" value="${CHASSIS_WIDTH/2.0}"/>

  <!-- Front Left -->
  <link name="wheel_front_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${DIFF_WHEEL_RADIUS}" length="${DIFF_WHEEL_WIDTH}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${DIFF_WHEEL_RADIUS}" length="${DIFF_WHEEL_WIDTH}"/>
      </geometry>
    </collision>
    <xacro:default_inertial
      mass="${DIFF_WHEEL_MASS}"
      ixx="${(DIFF_WHEEL_MASS/12.0) * (3*DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS + DIFF_WHEEL_WIDTH*DIFF_WHEEL_WIDTH)}"
      iyy="${(DIFF_WHEEL_MASS/2.0) * (DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS)}"
      izz="${(DIFF_WHEEL_MASS/12.0) * (3*DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS + DIFF_WHEEL_WIDTH*DIFF_WHEEL_WIDTH)}"/>
  </link>

  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left_link"/>
    <origin xyz="${DIFF_WHEEL_X_OFFSET} ${DIFF_WHEEL_Y_OFFSET} ${DIFF_WHEEL_RADIUS}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <transmission name="wheel_front_left_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wheel_front_left_joint">
      <hardwareInterface>velocity</hardwareInterface>
    </joint>
    <actuator name="wheel_front_left_motor">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- Front Right -->
  <link name="wheel_front_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${DIFF_WHEEL_RADIUS}" length="${DIFF_WHEEL_WIDTH}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${DIFF_WHEEL_RADIUS}" length="${DIFF_WHEEL_WIDTH}"/>
      </geometry>
    </collision>
    <xacro:default_inertial
      mass="${DIFF_WHEEL_MASS}"
      ixx="${(DIFF_WHEEL_MASS/12.0) * (3*DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS + DIFF_WHEEL_WIDTH*DIFF_WHEEL_WIDTH)}"
      iyy="${(DIFF_WHEEL_MASS/2.0) * (DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS)}"
      izz="${(DIFF_WHEEL_MASS/12.0) * (3*DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS + DIFF_WHEEL_WIDTH*DIFF_WHEEL_WIDTH)}"/>
  </link>

  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right_link"/>
    <origin xyz="${DIFF_WHEEL_X_OFFSET} ${-DIFF_WHEEL_Y_OFFSET} ${DIFF_WHEEL_RADIUS}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <transmission name="wheel_front_right_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wheel_front_right_joint">
      <hardwareInterface>velocity</hardwareInterface>
    </joint>
    <actuator name="wheel_front_right_motor">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- Rear Left -->
  <link name="wheel_rear_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${DIFF_WHEEL_RADIUS}" length="${DIFF_WHEEL_WIDTH}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${DIFF_WHEEL_RADIUS}" length="${DIFF_WHEEL_WIDTH}"/>
      </geometry>
    </collision>
    <xacro:default_inertial
      mass="${DIFF_WHEEL_MASS}"
      ixx="${(DIFF_WHEEL_MASS/12.0) * (3*DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS + DIFF_WHEEL_WIDTH*DIFF_WHEEL_WIDTH)}"
      iyy="${(DIFF_WHEEL_MASS/2.0) * (DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS)}"
      izz="${(DIFF_WHEEL_MASS/12.0) * (3*DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS + DIFF_WHEEL_WIDTH*DIFF_WHEEL_WIDTH)}"/>
  </link>

  <joint name="wheel_rear_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_left_link"/>
    <origin xyz="${-DIFF_WHEEL_X_OFFSET} ${DIFF_WHEEL_Y_OFFSET} ${DIFF_WHEEL_RADIUS}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <transmission name="wheel_rear_left_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wheel_rear_left_joint">
      <hardwareInterface>velocity</hardwareInterface>
    </joint>
    <actuator name="wheel_rear_left_motor">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- Rear Right -->
  <link name="wheel_rear_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${DIFF_WHEEL_RADIUS}" length="${DIFF_WHEEL_WIDTH}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${DIFF_WHEEL_RADIUS}" length="${DIFF_WHEEL_WIDTH}"/>
      </geometry>
    </collision>
    <xacro:default_inertial
      mass="${DIFF_WHEEL_MASS}"
      ixx="${(DIFF_WHEEL_MASS/12.0) * (3*DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS + DIFF_WHEEL_WIDTH*DIFF_WHEEL_WIDTH)}"
      iyy="${(DIFF_WHEEL_MASS/2.0) * (DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS)}"
      izz="${(DIFF_WHEEL_MASS/12.0) * (3*DIFF_WHEEL_RADIUS*DIFF_WHEEL_RADIUS + DIFF_WHEEL_WIDTH*DIFF_WHEEL_WIDTH)}"/>
  </link>

  <joint name="wheel_rear_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_right_link"/>
    <origin xyz="${-DIFF_WHEEL_X_OFFSET} ${-DIFF_WHEEL_Y_OFFSET} ${DIFF_WHEEL_RADIUS}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <transmission name="wheel_rear_right_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wheel_rear_right_joint">
      <hardwareInterface>velocity</hardwareInterface>
    </joint>
    <actuator name="wheel_rear_right_motor">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
</xacro:macro>

</robot>