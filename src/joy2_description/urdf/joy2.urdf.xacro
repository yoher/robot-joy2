<?xml version="1.0"?>

<robot xmlns:xacro="http://ros.org/wiki/xacro" name="joy2">

  <!-- Drive type argument -->
  <xacro:arg name="drive_type" default="mecanum"/>
  <xacro:property name="drive_type" value="${drive_type}"/>

  <!-- ================================================================= -->
  <!-- 1. PROPERTIES / CONSTANTS                                        -->
  <!-- ================================================================= -->

  <xacro:property name="M_PI" value="3.14159265359"/>

  <!-- Chassis Dimensions -->
  <xacro:property name="CHASSIS_LENGTH" value="0.4"/> <!-- 40 cm -->
  <xacro:property name="CHASSIS_WIDTH" value="0.3"/>  <!-- 30 cm -->
  <xacro:property name="CHASSIS_HEIGHT" value="0.1"/> <!-- 10 cm -->
  <xacro:property name="CHASSIS_MASS" value="5.0"/>

  <!-- IMU Placement -->
  <xacro:property name="IMU_Z_OFFSET" value="0.11"/> <!-- Slightly above the chassis top -->

  <!-- ================================================================= -->
  <!-- MATERIALS (Visualization Colors)                                  -->
  <!-- ================================================================= -->

  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.2 0.2 1.0"/>
  </material>

  <!-- ================================================================= -->
  <!-- INERTIA MACRO (Helper for Link Inertia)                           -->
  <!-- ================================================================= -->

  <xacro:macro name="default_inertial" params="mass ixx iyy izz">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${ixx}" ixy="0.0" ixz="0.0"
               iyy="${iyy}" iyz="0.0" izz="${izz}"/>
    </inertial>
  </xacro:macro>

  <!-- ================================================================= -->
  <!-- INCLUDE WHEEL SETUPS                                              -->
  <!-- ================================================================= -->

  <xacro:include filename="$(find joy2_description)/urdf/wheels_mecanum.xacro"/>
  <xacro:include filename="$(find joy2_description)/urdf/wheels_diff.xacro"/>

  <!-- ================================================================= -->
  <!-- BASE LINK (Chassis)                                               -->
  <!-- ================================================================= -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${CHASSIS_HEIGHT / 2}" rpy="0 0 0"/>
      <geometry>
        <box size="${CHASSIS_LENGTH} ${CHASSIS_WIDTH} ${CHASSIS_HEIGHT}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${CHASSIS_HEIGHT / 2}" rpy="0 0 0"/>
      <geometry>
        <box size="${CHASSIS_LENGTH} ${CHASSIS_WIDTH} ${CHASSIS_HEIGHT}"/>
      </geometry>
    </collision>
    <xacro:default_inertial mass="${CHASSIS_MASS}"
                            ixx="0.1" iyy="0.1" izz="0.1"/>
  </link>

  <!-- ================================================================= -->
  <!-- CONDITIONAL WHEEL SETUP                                           -->
  <!-- ================================================================= -->

  <xacro:if value="${drive_type == 'mecanum'}">
    <xacro:joy2_mecanum_wheels/>
  </xacro:if>

  <xacro:if value="${drive_type == 'diff'}">
    <xacro:joy2_diff_wheels/>
  </xacro:if>

  <!-- ================================================================= -->
  <!-- SENSOR DEFINITION (IMU)                                           -->
  <!-- ================================================================= -->

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <material name="red"/>
    </visual>
    <xacro:default_inertial mass="0.01"
                            ixx="1e-6" iyy="1e-6" izz="1e-6"/>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 ${IMU_Z_OFFSET}" rpy="0 0 0"/>
  </joint>

</robot>